# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Service role key — usada SOMENTE em rotas server-side (webhook). Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Hotmart
# Token enviado pela Hotmart no campo "hottok" do payload do webhook.
# Configurado no painel Hotmart em Ferramentas > Webhook.
HOTMART_WEBHOOK_TOKEN=seu-hottok-secreto

# E-mail (Resend) — usado para enviar credenciais de acesso após a compra
RESEND_API_KEY=sua-resend-api-key
EMAIL_FROM="Guia Instagram Ads <acesso@seudominio.com>"

# URL pública da aplicação (usada nos links de e-mail e redirect de recuperação de senha)
NEXT_PUBLIC_APP_URL=http://localhost:3000
